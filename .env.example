OPENAI_INPUT_COST_PER_1M_TOKENS=
OPENAI_OUTPUT_COST_PER_1M_TOKENS=
GUIDE_MAX_DEPTH=2
WEB_SEARCH_ALLOWED=false
RAG_SHARED_DIRECTORY=
RAG_WEBSITE_ALLOWLIST=
