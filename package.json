{
  "name": "onboarding-accelerator",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js onboarding assistant with server-side guidance, chat, and RAG services.",
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @onboarding/shared && npm run build -w @onboarding/web",
    "dev": "node scripts/dev.mjs",
    "docs:harness:update": "node scripts/update-harness-docs.mjs",
    "users:create": "node -r dotenv/config scripts/users-create.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "test": "npm run test -w @onboarding/web",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "jose": "^5.10.0",
    "next": "^15.4.0",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.51"
  }
}
