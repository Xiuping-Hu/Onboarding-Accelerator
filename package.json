{
  "name": "onboarding-accelerator",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js onboarding assistant with server-side guidance, chat, and RAG services.",
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run prisma:generate && npm run build -w @onboarding/shared && npm run build -w @onboarding/web",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "dev": "node scripts/dev.mjs",
    "docs:harness:update": "node scripts/update-harness-docs.mjs",
    "rag:ingest": "tsx scripts/rag-ingest.ts",
    "rag:reindex-snapshots": "tsx scripts/rag-reindex-snapshots.ts",
    "mastra:storage:init": "tsx scripts/mastra-storage-init.ts",
    "users:create": "tsx scripts/users-create.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "test": "npm run test -w @onboarding/web",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "prisma": "^7.8.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.5.0",
    "mammoth": "^1.12.0",
    "next": "^15.4.0",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "undici": "^7.16.0",
    "zod": "^3.25.51"
  }
}
